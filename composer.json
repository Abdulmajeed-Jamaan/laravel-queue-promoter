{
    "name": "abdulmajeed-jamaan/laravel-queue-promoter",
    "description": "A queue:work-style daemon that promotes due delayed and expired reserved jobs onto the ready queue for Laravel's Redis queue driver.",
    "keywords": [
        "laravel",
        "queue",
        "redis",
        "worker",
        "jobs",
        "autoscaling"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulmajeed Jamaan",
            "email": "abdulmajeed.jamaan@outlook.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "AbdulmajeedJamaan\\QueuePromoter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AbdulmajeedJamaan\\QueuePromoter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AbdulmajeedJamaan\\QueuePromoter\\QueuePromoterServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
